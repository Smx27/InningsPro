{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "../../packages/shared-types/src/*"
      ],
      "@schema/*": [
        "../../packages/export-schema/src/*"
      ],
      "@ui/*": [
        "../../packages/ui-tokens/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
